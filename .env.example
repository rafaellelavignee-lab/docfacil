# Postgres (Neon / Vercel Postgres em produção; `npx prisma dev` em dev local)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/docfacil?schema=public"
# Necessária apenas para `prisma migrate dev` (shadow database)
SHADOW_DATABASE_URL=""

# Auth.js (v5 detecta a URL automaticamente; AUTH_URL só é necessária atrás de certos proxies)
AUTH_SECRET="" # gerar com: npx auth secret
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_WEBHOOK_SECRET=""
# Preço do documento avulso (contas empresa), em centavos
PRICE_PER_DOCUMENT_CENTS="1990"

# Vercel Blob (storage de PDFs)
BLOB_READ_WRITE_TOKEN=""

# Upstash Redis (rate limit / cache)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"
